<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VANDI — Velocity · Autonomy · Networks · Data · Intelligence</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    /* ── TOKENS ─────────────────────────────────────────── */
    :root {
      --night:      #080b0f;
      --deep:       #0d1117;
      --surface:    #131920;
      --card:       #181f28;
      --border:     rgba(255,255,255,0.07);
      --border-hi:  rgba(255,255,255,0.13);
      --white:      #f0ede8;
      --muted:      rgba(240,237,232,0.48);
      --dim:        rgba(240,237,232,0.24);
      --gold:       #c9a84c;
      --gold-dim:   rgba(201,168,76,0.15);
      --gold-glow:  rgba(201,168,76,0.07);
      --teal:       #2dd4bf;
      --teal-dim:   rgba(45,212,191,0.08);
      --red-dim:    rgba(239,68,68,0.1);
      --radius:     12px;
      --radius-lg:  20px;
      --max:        1180px;
      --serif:      'Cormorant Garamond', Georgia, serif;
      --sans:       'Syne', system-ui, sans-serif;
    }
 
    /* ── RESET ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--sans);
      background: var(--night);
      color: var(--white);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    button { cursor: pointer; font-family: var(--sans); }
 
    /* ── GRAIN ──────────────────────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.027;
      pointer-events: none;
      z-index: 9999;
    }
 
    /* ── ANIMATIONS ─────────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes shimmer {
      0%   { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.4; }
    }
    @keyframes scrollL {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @keyframes blink { 50% { opacity: 0; } }
 
    .fade-up   { animation: fadeUp 0.7s ease both; }
    .fade-up-2 { animation: fadeUp 0.7s 0.12s ease both; }
    .fade-up-3 { animation: fadeUp 0.7s 0.24s ease both; }
    .fade-up-4 { animation: fadeUp 0.7s 0.36s ease both; }
 
    /* ── NAV ────────────────────────────────────────────── */
    nav {
      position: sticky; top: 0; z-index: 200;
      padding: 0 2rem;
      background: rgba(8,11,15,0.88);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: var(--max); margin: 0 auto;
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { display: flex; align-items: baseline; gap: 0.5rem; }
    .nav-wordmark {
      font-family: var(--sans);
      font-size: 1.5rem; font-weight: 800; letter-spacing: 0.14em;
      background: linear-gradient(90deg, var(--gold), #e8c96a, var(--gold));
      background-size: 200% auto;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 4s linear infinite;
    }
    .nav-tag { font-size: 0.64rem; font-weight: 500; letter-spacing: 0.08em; color: var(--dim); text-transform: uppercase; }
    .nav-links { display: flex; align-items: center; gap: 2rem; }
    .nav-links a {
      font-size: 0.78rem; font-weight: 500; letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--muted); transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-cta {
      background: var(--gold); color: var(--night); border: none;
      padding: 0.5rem 1.3rem; border-radius: 6px;
      font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      transition: opacity 0.15s, transform 0.15s;
    }
    .nav-cta:hover { opacity: 0.88; transform: translateY(-1px); }
 
    /* ── HERO ───────────────────────────────────────────── */
    .hero {
      position: relative; min-height: 92vh;
      display: flex; align-items: center;
      padding: 6rem 2rem 5rem; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 30% 40%, rgba(201,168,76,0.055) 0%, transparent 70%),
        radial-gradient(ellipse 50% 50% at 80% 70%, rgba(45,212,191,0.025) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
      background-size: 64px 64px;
      mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 100%);
      pointer-events: none;
    }
    .hero-inner {
      position: relative; max-width: var(--max); margin: 0 auto; width: 100%;
      display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 5rem; align-items: center;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.6rem;
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--gold); border: 1px solid var(--gold-dim);
      background: var(--gold-glow); padding: 0.32rem 0.85rem; border-radius: 100px;
      margin-bottom: 1.75rem;
    }
    .pulse-dot {
      width: 7px; height: 7px; background: var(--gold); border-radius: 50%;
      animation: pulse 2s ease infinite;
    }
    .hero h1 {
      font-family: var(--serif);
      font-size: clamp(2.8rem, 5vw, 4.5rem); font-weight: 300;
      line-height: 1.08; letter-spacing: -0.01em; margin-bottom: 1.5rem;
    }
    .hero h1 em { font-style: italic; color: var(--gold); }
    .hero h1 strong { font-weight: 600; }
    .hero-sub {
      color: var(--muted); font-size: 1rem; font-weight: 400;
      line-height: 1.75; margin-bottom: 2.25rem; max-width: 490px;
    }
    .acronym-row { display: flex; gap: 0.65rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
    .acronym-pill {
      font-size: 0.68rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      padding: 0.28rem 0.7rem; border-radius: 100px; border: 1px solid var(--border-hi); color: var(--muted);
    }
    .acronym-pill b { color: var(--gold); }
 
    /* Hero form */
    .hero-form {
      background: var(--card); border: 1px solid var(--border-hi);
      border-radius: var(--radius-lg); padding: 2rem;
    }
    .hero-form-label {
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 1.25rem;
    }
    .form-group { margin-bottom: 0.8rem; }
    .form-group input {
      width: 100%; background: var(--surface); border: 1px solid var(--border-hi);
      border-radius: 8px; padding: 0.78rem 1rem;
      font-family: var(--sans); font-size: 0.875rem; color: var(--white);
      outline: none; transition: border-color 0.2s;
    }
    .form-group input::placeholder { color: var(--dim); }
    .form-group input:focus { border-color: var(--gold); }
    .form-submit {
      width: 100%; background: var(--gold); color: var(--night); border: none;
      padding: 0.88rem; border-radius: 8px;
      font-size: 0.875rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
      margin-top: 0.4rem; transition: opacity 0.15s, transform 0.15s;
    }
    .form-submit:hover { opacity: 0.9; transform: translateY(-1px); }
    .form-trust {
      font-size: 0.7rem; color: var(--dim); text-align: center;
      margin-top: 0.9rem; line-height: 1.6;
    }
    .form-badges {
      display: flex; gap: 0.5rem; justify-content: center; margin-top: 0.75rem; flex-wrap: wrap;
    }
    .form-badge {
      font-size: 0.62rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--dim); border: 1px solid var(--border); border-radius: 4px; padding: 0.2rem 0.5rem;
    }
 
    /* ── SCROLL TRACKS ──────────────────────────────────── */
    .scroll-section {
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      padding: 0; overflow: hidden;
    }
    .scroll-label {
      text-align: center; padding: 2rem 0 1.25rem;
      font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--dim);
    }
    .scroll-track-wrap { overflow: hidden; padding-bottom: 2rem; }
    .scroll-track {
      display: flex; width: max-content; align-items: center;
      animation: scrollL 28s linear infinite;
    }
    .scroll-track:hover { animation-play-state: paused; }
    .scroll-track + .scroll-track { margin-top: 0.75rem; animation-duration: 22s; animation-direction: reverse; }
 
    .venue-chip {
      font-family: var(--sans); font-size: 0.73rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--dim);
      white-space: nowrap; margin: 0 1.5rem;
      padding: 0.38rem 1rem; border: 1px solid var(--border); border-radius: 6px;
      transition: color 0.2s, border-color 0.2s;
    }
    .venue-chip:hover { color: var(--gold); border-color: var(--gold-dim); }
 
    .integration-chip {
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em;
      color: var(--muted); white-space: nowrap; margin: 0 1.25rem;
      padding: 0.35rem 0.9rem; border: 1px solid var(--border-hi); border-radius: 20px;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .integration-chip span { color: var(--gold); font-size: 0.9rem; }
 
    /* ── STATS ──────────────────────────────────────────── */
    .stats { background: var(--surface); padding: 4.5rem 2rem; }
    .stats-grid {
      max-width: var(--max); margin: 0 auto;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;
    }
    .stat-item { text-align: center; }
    .stat-number {
      font-family: var(--serif); font-size: clamp(2.4rem, 4vw, 3.5rem); font-weight: 600;
      color: var(--gold); line-height: 1; margin-bottom: 0.5rem;
    }
    .stat-label { font-size: 0.78rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); }
 
    /* ── PAIN SECTION (from Understory) ─────────────────── */
    .pain {
      background: var(--deep); padding: 6rem 2rem;
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    }
    .pain-inner {
      max-width: var(--max); margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
    }
    .pain-cards { display: flex; flex-direction: column; gap: 1rem; }
    .pain-card {
      display: flex; align-items: flex-start; gap: 1rem;
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 1.25rem;
    }
    .pain-icon {
      width: 40px; height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; flex-shrink: 0;
    }
    .pain-icon.red { background: var(--red-dim); }
    .pain-icon.yellow { background: rgba(234,179,8,0.1); }
    .pain-icon.orange { background: rgba(249,115,22,0.1); }
    .pain-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }
    .pain-card strong { color: var(--white); display: block; margin-bottom: 0.25rem; font-size: 0.88rem; }
    .pain-text h2 {
      font-family: var(--serif);
      font-size: clamp(1.9rem, 3.5vw, 2.8rem); font-weight: 300; line-height: 1.2;
      letter-spacing: -0.01em; margin-bottom: 1.5rem;
    }
    .pain-text h2 em { font-style: italic; color: var(--gold); }
    .pain-text p { color: var(--muted); font-size: 0.95rem; line-height: 1.8; margin-bottom: 1rem; }
 
    /* ── HOW IT WORKS (from Understory) ─────────────────── */
    .how { background: var(--night); padding: 6rem 2rem; }
    .how-inner { max-width: var(--max); margin: 0 auto; }
    .how-steps {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 4rem;
    }
    .how-step {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 2rem; position: relative;
      transition: border-color 0.25s, transform 0.25s;
    }
    .how-step:hover { border-color: var(--border-hi); transform: translateY(-3px); }
    .step-num {
      font-family: var(--serif); font-size: 3.5rem; font-weight: 300;
      color: var(--gold-dim); line-height: 1; margin-bottom: 1rem;
      border-bottom: 1px solid var(--border); padding-bottom: 1rem;
    }
    .how-step h3 {
      font-size: 1rem; font-weight: 700; letter-spacing: 0.03em; margin-bottom: 0.75rem;
    }
    .how-step p { font-size: 0.85rem; color: var(--muted); line-height: 1.7; }
    .how-step .step-time {
      margin-top: 1.5rem; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--teal);
    }
    /* connector line */
    .how-steps { position: relative; }
    .how-steps::before {
      content: '';
      position: absolute; top: 3.5rem; left: calc(33.33% + 1rem); right: calc(33.33% + 1rem);
      height: 1px; background: linear-gradient(90deg, var(--gold-dim), var(--gold-dim));
      pointer-events: none;
    }
 
    /* ── FEATURES ───────────────────────────────────────── */
    .features { background: var(--deep); padding: 6rem 2rem; }
    .features-header {
      margin-bottom: 3rem;
      display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: end;
    }
 
    /* Tab switcher (from Understory) */
    .feature-tabs { display: flex; gap: 0.5rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
    .tab-btn {
      background: var(--card); border: 1px solid var(--border);
      color: var(--muted); padding: 0.5rem 1.1rem; border-radius: 100px;
      font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em;
      transition: all 0.2s; cursor: pointer;
    }
    .tab-btn.active, .tab-btn:hover {
      background: var(--gold-dim); border-color: var(--gold-dim); color: var(--gold);
    }
 
    .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .features-grid.hidden { display: none; }
 
    .feature-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 1.75rem; position: relative; overflow: hidden;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }
    .feature-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .feature-card:hover { border-color: var(--border-hi); transform: translateY(-4px); box-shadow: 0 20px 48px rgba(0,0,0,0.4); }
    .feature-card:hover::before { opacity: 1; }
    .feature-icon {
      width: 44px; height: 44px; background: var(--gold-glow); border: 1px solid var(--gold-dim);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.25rem; font-size: 1.2rem;
    }
    .feature-card h3 { font-size: 0.9rem; font-weight: 700; letter-spacing: 0.04em; margin-bottom: 0.6rem; }
    .feature-card p { font-size: 0.83rem; color: var(--muted); line-height: 1.65; }
    .feature-tag {
      display: inline-block; margin-top: 1rem;
      font-size: 0.63rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--teal); background: var(--teal-dim); border-radius: 100px; padding: 0.2rem 0.6rem;
    }
 
    /* ── AGENTS ─────────────────────────────────────────── */
    .agents { background: var(--night); padding: 6rem 2rem; position: relative; overflow: hidden; }
    .agents::after {
      content: ''; position: absolute; bottom: -200px; right: -200px;
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(45,212,191,0.04) 0%, transparent 70%);
      pointer-events: none;
    }
    .agents-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .agents-list { display: flex; flex-direction: column; gap: 0.85rem; margin-top: 2rem; }
    .agent-row {
      display: flex; align-items: flex-start; gap: 1rem;
      padding: 1.1rem 1.25rem; background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); transition: border-color 0.2s; cursor: default;
    }
    .agent-row:hover { border-color: var(--border-hi); }
    .agent-dot {
      width: 9px; height: 9px; background: var(--teal); border-radius: 50%;
      margin-top: 5px; flex-shrink: 0; box-shadow: 0 0 8px rgba(45,212,191,0.5);
    }
    .agent-row h4 { font-size: 0.84rem; font-weight: 700; margin-bottom: 0.2rem; letter-spacing: 0.03em; }
    .agent-row p { font-size: 0.79rem; color: var(--muted); line-height: 1.5; }
 
    .agents-visual {
      background: var(--card); border: 1px solid var(--border-hi);
      border-radius: var(--radius-lg); padding: 1.75rem; min-height: 400px;
      display: flex; flex-direction: column; gap: 0;
    }
    .terminal-bar { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.25rem; }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-r { background: #ff5f57; } .dot-y { background: #febc2e; } .dot-g { background: #28c840; }
    .t-title { margin-left: auto; font-size: 0.68rem; color: var(--dim); letter-spacing: 0.06em; }
    .log-line {
      font-family: 'Courier New', monospace; font-size: 0.73rem; line-height: 1.9;
      padding: 0.15rem 0; border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .lt { color: var(--dim); margin-right: 0.7rem; }
    .la { color: var(--gold); margin-right: 0.4rem; font-weight: bold; }
    .lm { color: rgba(240,237,232,0.65); }
    .lok { color: var(--teal); }
    .cursor { display: inline-block; width: 7px; height: 13px; background: var(--gold); vertical-align: middle; animation: blink 1s step-end infinite; }
 
    /* ── TESTIMONIALS (from Understory) ─────────────────── */
    .testimonials { background: var(--surface); padding: 6rem 2rem; }
    .testimonials-inner { max-width: var(--max); margin: 0 auto; }
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3.5rem; }
    .testimonial-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 1.75rem;
      transition: border-color 0.2s, transform 0.2s;
    }
    .testimonial-card:hover { border-color: var(--border-hi); transform: translateY(-2px); }
    .t-stars { color: var(--gold); font-size: 0.85rem; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .t-quote {
      font-family: var(--serif); font-size: 1.05rem; font-weight: 300; font-style: italic;
      line-height: 1.6; color: var(--white); margin-bottom: 1.5rem;
    }
    .t-author { display: flex; align-items: center; gap: 0.85rem; }
    .t-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--gold-dim); border: 1px solid var(--gold-dim);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.85rem; font-weight: 700; color: var(--gold); flex-shrink: 0;
    }
    .t-name { font-size: 0.84rem; font-weight: 700; }
    .t-role { font-size: 0.75rem; color: var(--muted); margin-top: 0.1rem; }
 
    /* ── JUNG ───────────────────────────────────────────── */
    .jung {
      background: var(--deep); padding: 6rem 2rem;
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); text-align: center;
    }
    .jung-inner { max-width: 760px; margin: 0 auto; }
    .jung blockquote {
      font-family: var(--serif); font-size: clamp(1.6rem, 3vw, 2.3rem); font-weight: 300;
      font-style: italic; line-height: 1.4; color: var(--white); margin-bottom: 1.5rem;
    }
    .jung blockquote em { color: var(--gold); font-style: normal; }
    .jung cite { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim); }
    .jung-body { margin-top: 2rem; color: var(--muted); font-size: 0.92rem; line-height: 1.8; }
 
    /* ── FAQ ────────────────────────────────────────────── */
    .faq { background: var(--night); padding: 6rem 2rem; }
    .faq-layout { display: grid; grid-template-columns: 1fr 1.6fr; gap: 5rem; align-items: start; }
    .faq-sticky { position: sticky; top: 90px; }
    .faq-item { border-bottom: 1px solid var(--border); }
    .faq-item:first-of-type { border-top: 1px solid var(--border); }
    .faq-q {
      width: 100%; background: none; border: none; text-align: left;
      padding: 1.2rem 0; font-family: var(--sans); font-size: 0.88rem; font-weight: 600;
